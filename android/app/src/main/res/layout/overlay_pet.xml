<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- Body + cosmetic move together: tap-bounce and the breathe loop
         animate this frame, and OverlayService resizes it to the user's
         pet-size preference. -->
    <FrameLayout
        android:id="@+id/petSprite"
        android:layout_width="88dp"
        android:layout_height="88dp">

        <ImageView
            android:id="@+id/petBody"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/pet_clawd_idle"
            android:contentDescription="@string/app_name" />

        <ImageView
            android:id="@+id/petCosmetic"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:importantForAccessibility="no" />
    </FrameLayout>

    <TextView
        android:id="@+id/petLevelBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:background="@drawable/bg_level_badge"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="1dp"
        android:paddingBottom="1dp"
        android:textColor="@color/text_primary"
        android:textSize="10sp"
        android:textStyle="bold" />

</FrameLayout>
